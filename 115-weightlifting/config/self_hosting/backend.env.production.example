# Production environment for the Django backend.
#
# Required: SECRET_KEY, DEBUG=False. Without these, the server refuses to
# boot (see config/settings.py SECRET_KEY guard).
#
# Required when running behind a TLS-terminating proxy (Caddy, nginx,
# cloud LB): the proxy MUST forward X-Forwarded-Proto=https. With DEBUG=False
# Django reads SECURE_PROXY_SSL_HEADER and marks the request as secure,
# which lets the Secure wl_refresh cookie and SECURE_SSL_REDIRECT behave.
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=your-domain.example
CORS_ALLOWED_ORIGINS=https://your-domain.example
CSRF_TRUSTED_ORIGINS=https://your-domain.example
DATABASE_URL=postgresql://postgres:password@db-host:5432/weightlifting_db

# Coach self-signup gate. Leave unset to disable coach registration entirely.
# Rotate this value whenever someone leaves the coaching staff.
COACH_SIGNUP_CODE=replace-with-a-shared-secret

# Throttle rates (optional; defaults in settings.py are reasonable).
# Format: "<N>/second|minute|hour|day".
# THROTTLE_ANON=60/min
# THROTTLE_USER=240/min
# THROTTLE_LOGIN=30/min
# THROTTLE_REGISTER=10/min

# TLS enforcement (optional).
#   SECURE_SSL_REDIRECT=True  -- Django 301s plain HTTP to HTTPS. Safe when
#                                the proxy always reaches the app on a
#                                loopback/HTTPS-terminated path. Set to False
#                                if a health check targets the app over plain
#                                HTTP and gets redirected into a loop.
#   SECURE_HSTS_SECONDS       -- defaults to 31536000 (1 year). Set to 0
#                                while you are still validating your domain.
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
