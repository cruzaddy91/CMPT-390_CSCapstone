your-domain.example {
    root * /srv/weightlifting/app/115-weightlifting/src/frontend/dist
    encode gzip zstd

    # Forward TLS context + real client IP to Django so request.is_secure()
    # reports correctly, the wl_refresh cookie is accepted, and CSRF trusted
    # origins line up. Caddy forwards these by default; listing them here
    # keeps the contract explicit for future readers.
    handle /api/* {
        reverse_proxy 127.0.0.1:8000 {
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-For  {remote_host}
            header_up X-Real-IP        {remote_host}
            header_up Host             {host}
        }
    }

    file_server
    try_files {path} /index.html
}
