# Leave VITE_API_BASE_URL blank to use the Vite dev proxy (/api -> :8000).
# Same-origin is required so the httpOnly wl_refresh cookie (SameSite=Lax)
# flows back to the frontend during local development.
#
# For a cross-origin prod deployment (frontend served from a different
# origin than the API), set this to the fully-qualified API origin AND
# make sure the backend sets SameSite=None; Secure on its cookies.
VITE_API_BASE_URL=
