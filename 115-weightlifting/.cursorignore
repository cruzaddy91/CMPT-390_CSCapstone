# Generated runtime and logs
var/
logs/
*.log
*.pid
*.pid.lock

# Python runtime
src/backend/venv/
src/backend/__pycache__/
src/**/__pycache__/
.pytest_cache/
.mypy_cache/

# Frontend build/runtime
src/frontend/node_modules/
src/frontend/dist/

# Generated backend assets
src/backend/staticfiles/
src/backend/media/

# Local databases and exports
*.db
*.sqlite
*.sqlite3

# Local secrets
src/backend/.env
src/frontend/.env
src/backend/.env.*
src/frontend/.env.*
!src/backend/.env.example
!src/frontend/.env.example

# Large local artifacts
var/backups/
var/releases/
var/reports/events/
